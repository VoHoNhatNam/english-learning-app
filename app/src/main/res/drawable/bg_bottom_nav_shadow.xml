<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Lớp bóng đổ (Shadow) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="34dp" android:topRightRadius="34dp" />
            <gradient
                android:angle="90"
                android:startColor="#00000000"
                android:centerColor="#08000000"
                android:endColor="#15000000" />
        </shape>
    </item>

    <!-- Lớp nền trắng (Main Background) - Đè lên lớp bóng, lùi xuống 2dp để lộ bóng phía trên -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <corners android:topLeftRadius="32dp" android:topRightRadius="32dp" />
        </shape>
    </item>
</layer-list>