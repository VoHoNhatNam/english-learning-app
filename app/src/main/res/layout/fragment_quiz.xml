<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB"
    android:padding="16dp">

    <!-- PROGRESS -->
    <ProgressBar
        android:id="@+id/quizProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:progress="10"
        android:progressDrawable="@drawable/custom_progress_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtQuizCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Câu 1 / 10"
        android:textColor="#666"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/quizProgressBar"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- QUESTION CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtQuizCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/txtQuestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Từ nào nghĩa là 'Quả táo'?"
                android:textSize="20sp"
                android:textColor="#222"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ANSWERS -->
    <LinearLayout
        android:id="@+id/layoutAnswers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardQuestion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Answer 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswer1"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="12dp"
            android:text="Orange"
            android:textAllCaps="false"
            android:textColor="#333"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="18dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            android:elevation="2dp"/>

        <!-- Answer 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswer2"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="12dp"
            android:text="Apple"
            android:textAllCaps="false"
            android:textColor="#333"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="18dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            android:elevation="2dp"/>

        <!-- Answer 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswer3"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="12dp"
            android:text="Banana"
            android:textAllCaps="false"
            android:textColor="#333"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="18dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            android:elevation="2dp"/>

        <!-- Answer 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnswer4"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Grape"
            android:textAllCaps="false"
            android:textColor="#333"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="18dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            android:elevation="2dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>