<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mục tiêu của bạn là gì?"
        android:textColor="#222"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chúng tôi sẽ chuẩn bị tài liệu học phù hợp với môi trường của bạn."
        android:textColor="#666"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"/>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSchoolUni"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp"
        android:text="Sinh viên Đại học"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:strokeColor="#E0E0E0" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSchoolWorker"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp"
        android:text="Người đã đi làm"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:strokeColor="#E0E0E0" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSchoolOther"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="Khác / Sở thích"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:strokeColor="#E0E0E0" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Navigation Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSchoolNext"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Tiếp tục"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        android:enabled="false" />

</LinearLayout>