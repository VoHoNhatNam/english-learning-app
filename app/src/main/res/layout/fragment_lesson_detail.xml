<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB"
    android:padding="16dp">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#333" />

        <TextView
            android:id="@+id/txtLessonDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Tên bài học"
            android:textColor="#222"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- CARD TIẾN ĐỘ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="24dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiến độ hoàn thành"
                android:textColor="#666"
                android:textSize="14sp"/>

            <ProgressBar
                android:id="@+id/progressLesson"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="10dp"
                android:progress="40"
                android:progressDrawable="@drawable/progress_custom"/>

            <TextView
                android:id="@+id/txtProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:text="40%"
                android:textColor="#4A6CF7"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bạn muốn học gì?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#222"
        android:layout_marginBottom="12dp"/>

    <!-- BUTTON VOCAB -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVocabulary"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="Học từ vựng"
        android:textColor="#333"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp"

        android:backgroundTint="#FFFFFF"
        app:cornerRadius="16dp"
        app:strokeColor="#4A6CF7"
        app:strokeWidth="1dp"

        app:icon="@drawable/ic_vocab"
        app:iconTint="#4A6CF7"
        app:iconPadding="12dp"
        app:iconGravity="textStart"/>

    <!-- BUTTON QUIZ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQuiz"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="Làm trắc nghiệm"
        android:textColor="#333"
        android:textAllCaps="false"

        android:backgroundTint="#FFFFFF"
        app:cornerRadius="16dp"
        app:strokeColor="#6C63FF"
        app:strokeWidth="1dp"

        app:icon="@drawable/ic_quiz"
        app:iconTint="#6C63FF"
        app:iconPadding="12dp"
        app:iconGravity="textStart"/>

</LinearLayout>