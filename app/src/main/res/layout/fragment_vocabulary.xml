<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB"
    android:padding="16dp">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnBackVocab"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="#333" />

        <TextView
            android:id="@+id/txtProgressIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="1 / 10"
            android:textSize="16sp"
            android:textColor="#666"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- FLASHCARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="25dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- WORD -->
            <TextView
                android:id="@+id/txtWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello"
                android:textColor="#4A6CF7"
                android:textSize="42sp"
                android:textStyle="bold"/>

            <!-- PHONETIC -->
            <TextView
                android:id="@+id/txtPhonetic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/həˈloʊ/"
                android:textColor="#888"
                android:textSize="18sp"
                android:layout_marginTop="6dp"/>

            <!-- SPEAK BUTTON -->
            <ImageButton
                android:id="@+id/btnSpeak"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/circle_bg"
                android:src="@drawable/ic_volume"
                android:elevation="4dp"
                app:tint="#FFFFFF" />

            <!-- DIVIDER -->
            <View
                android:layout_width="80dp"
                android:layout_height="2dp"
                android:background="#E5E7EB"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"/>

            <!-- MEANING -->
            <TextView
                android:id="@+id/txtMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xin chào"
                android:textColor="#222"
                android:textSize="26sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- BUTTON NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="Quay lại"
            android:textAllCaps="false"
            android:textColor="#333"

            android:backgroundTint="#E5E7EB"
            app:cornerRadius="14dp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="Tiếp theo"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"

            android:backgroundTint="#4A6CF7"
            app:cornerRadius="14dp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>