<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FD"
    android:padding="24dp">

    <!-- 1. Thanh tiến độ mượt mà hơn -->
    <ProgressBar
        android:id="@+id/fillWordProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:progress="30"
        android:progressDrawable="@drawable/custom_progress_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtProgress" />

    <TextView
        android:id="@+id/txtProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 / 10"
        android:textColor="#546E7A"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/fillWordProgressBar"
        app:layout_constraintBottom_toBottomOf="@id/fillWordProgressBar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 2. Thẻ câu hỏi thiết kế lại (Dạng Flashcard học thuật) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeColor="#E0E4EC"
        app:strokeWidth="1.5dp"
        app:layout_constraintTop_toBottomOf="@id/fillWordProgressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_book"
                android:layout_marginBottom="16dp"
                app:tint="#4A6CF7"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEFINITION"
                android:textSize="11sp"
                android:textColor="#90A4AE"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/txtQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A very large marine mammal that has a blowhole on top of its head."
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#263238"
                android:gravity="center"
                android:lineSpacingExtra="6dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 3. Khu vực nhập liệu (Gọn gàng và tập trung) -->
    <EditText
        android:id="@+id/edtAnswer"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:hint="Type your answer..."
        android:textSize="20sp"
        android:gravity="center"
        android:inputType="textVisiblePassword|textNoSuggestions"
        android:textColor="#4A6CF7"
        android:textStyle="bold"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_input_rounded"
        app:layout_constraintTop_toBottomOf="@id/cardQuestion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 4. Thông báo kết quả (Sẽ hiện khi Check) -->
    <TextView
        android:id="@+id/txtResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/edtAnswer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 5. Nút kiểm tra (Đặt ở cuối màn hình cho dễ bấm bằng một tay) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheck"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Verify Answer"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#4A6CF7"
        app:cornerRadius="30dp"
        app:elevation="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>