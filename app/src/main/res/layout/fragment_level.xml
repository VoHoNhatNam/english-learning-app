<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trình độ của bạn?"
        android:textColor="#222"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đừng lo lắng, bạn có thể thay đổi lộ trình học sau này."
        android:textColor="#666"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"/>

    <!-- Beginner -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLevelBeginner"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="12dp"
        android:text="Mới bắt đầu\n(Chưa biết gì hoặc biết rất ít)"
        android:textAllCaps="false"
        android:textSize="15sp"
        app:cornerRadius="16dp"
        app:strokeColor="#E0E0E0" />

    <!-- Intermediate -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLevelInter"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="12dp"
        android:text="Trung bình\n(Có thể giao tiếp cơ bản)"
        android:textAllCaps="false"
        android:textSize="15sp"
        app:cornerRadius="16dp"
        app:strokeColor="#E0E0E0" />

    <!-- Advanced -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLevelAdvanced"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Nâng cao\n(Muốn học chuyên sâu, học thuật)"
        android:textAllCaps="false"
        android:textSize="15sp"
        app:cornerRadius="16dp"
        app:strokeColor="#E0E0E0" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLevelFinish"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Hoàn tất"
        android:textColor="#FFF"
        android:backgroundTint="#4A6CF7"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        android:enabled="false" />

</LinearLayout>
