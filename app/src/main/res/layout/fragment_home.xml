<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- SEARCH -->
    <EditText
        android:id="@+id/searchInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:hint="Tìm từ vựng..."
        android:padding="12dp"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="10dp"
        android:background="@drawable/search_bg" />

    <!-- FEATURE GRID -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:padding="14dp">
        <Button android:id="@+id/btnFlashcard" android:text="Flashcard" android:layout_columnWeight="1" android:layout_margin="8dp" android:backgroundTint="#4A6CF7"/>
        <Button android:id="@+id/btnQuiz" android:text="Trắc nghiệm" android:layout_columnWeight="1" android:layout_margin="8dp" android:backgroundTint="#6C63FF"/>
        <Button android:id="@+id/btnFill" android:text="Điền từ" android:layout_columnWeight="1" android:layout_margin="8dp" android:backgroundTint="#FF7A59"/>
        <Button android:id="@+id/btnListening" android:text="Luyện nghe" android:layout_columnWeight="1" android:layout_margin="8dp" android:backgroundTint="#2BB673"/>
    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bài học hôm nay"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"/>

    <!-- LESSON LIST -->
    <ListView
        android:id="@+id/listLesson"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        android:dividerHeight="8dp"
        android:divider="@android:color/transparent"/>
</LinearLayout>