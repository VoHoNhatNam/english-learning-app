<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <include
        android:id="@+id/header"
        layout="@layout/layout_main_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHIÊN HỌC HIỆN TẠI"
                android:textColor="#757575"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <!-- Lộ trình hiện tại Badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRoadmap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardBackgroundColor="#F1F8E9">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle"
                        android:backgroundTint="#2E7D32" />
                    <TextView
                        android:id="@+id/tvCurrentRoadmap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Lộ trình: Đang tải..."
                        android:textColor="#2E7D32"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Chào mừng trở lại,\nElara."
                android:textColor="#1A1A1A"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineHeight="38sp" />

            <!-- Chart Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#F5F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <!-- Mock Bars -->
                        <View android:id="@+id/bar1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="60dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />
                        <View android:id="@+id/bar2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="80dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />
                        <View android:id="@+id/bar3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />
                        <View android:id="@+id/bar4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="100dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />
                        <View android:id="@+id/bar5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="70dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />
                        <View android:id="@+id/bar6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="110dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />
                        <View android:id="@+id/bar7" android:layout_width="0dp" android:layout_weight="1" android:layout_height="90dp" android:layout_marginHorizontal="4dp" android:background="@drawable/bg_bar_chart" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                        <TextView android:id="@+id/tvDay1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TH 2" android:gravity="center" android:textSize="10sp" android:textColor="#757575" />
                        <TextView android:id="@+id/tvDay2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TH 3" android:gravity="center" android:textSize="10sp" android:textColor="#757575" />
                        <TextView android:id="@+id/tvDay3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TH 4" android:gravity="center" android:textSize="10sp" android:textColor="#757575" />
                        <TextView android:id="@+id/tvDay4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TH 5" android:gravity="center" android:textSize="10sp" android:textColor="#757575" />
                        <TextView android:id="@+id/tvDay5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TH 6" android:gravity="center" android:textSize="10sp" android:textColor="#757575" />
                        <TextView android:id="@+id/tvDay6" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TH 7" android:gravity="center" android:textSize="10sp" android:textColor="#757575" />
                        <TextView android:id="@+id/tvDay7" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="CN" android:gravity="center" android:textSize="10sp" android:textColor="#2E7D32" android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="84%"
                        android:textColor="#2E7D32"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Độ chính xác về ngữ nghĩa của bạn đã tăng 12%\ntrong tuần này."
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:lineHeight="18sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Tutor Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lnChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#2D6A4F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trau dồi sự lưu loát"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Tham gia vào cuộc đối thoại được chọn lọc với gia sư ngôn ngữ AI của chúng tôi để nắm vững các cấu trúc cú pháp phức tạp thông qua phản hồi thời gian thực."
                        android:textColor="#B7DBCB"
                        android:textSize="14sp"
                        android:lineHeight="20sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTalkAI"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Trò chuyện với Gia sư AI"
                        android:textColor="#2D6A4F"
                        android:textAllCaps="false"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="12dp"
                        app:cornerRadius="24dp"
                        app:backgroundTint="#FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Learning Modules -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lnFlashcard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#F5F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_grammar_abstract" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="UNIT 04"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Ngữ pháp"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Nắm vững những sắc thái tinh tế của thế giả định trong các câu điều kiện."
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:lineHeight="18sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Vocabulary Module -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lnQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#F5F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_lexicon_abstract" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="TỪ ĐIỂN"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Từ vựng"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Mở rộng vốn từ vựng học thuật của bạn với 50 thuật ngữ tần suất cao được chọn lọc."
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:lineHeight="18sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reading Module -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lnMore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#F5F7F5"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_editorial_abstract" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="XÃ LUẬN"
                            android:textColor="#757575"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Đọc hiểu"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Phân tích một bài xã luận đương đại về đạo đức kỹ thuật số và ngôn ngữ học."
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:lineHeight="18sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>