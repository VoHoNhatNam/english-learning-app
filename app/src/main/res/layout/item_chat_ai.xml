<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="64dp"
        android:background="@drawable/bg_chat_ai"
        android:backgroundTint="#9D50FF"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:text="AI message"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <!-- Grammar/Word buttons (Hidden by default for AI Curator) -->
        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_color_green"
                android:backgroundTint="#FFDDA0"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_check"
                    app:tint="#251A00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Grammar Fix"
                    android:textColor="#251A00"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_color_blue"
                android:backgroundTint="#D9E2FF"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_book"
                    app:tint="#0066FF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Word Definition"
                    android:textColor="#0066FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutCorrection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EADDFF"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvCorrection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correction details here..."
                android:textColor="#24005A"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="6dp"
        android:text="CONVERSATION STARTER"
        android:textColor="#74777F"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>