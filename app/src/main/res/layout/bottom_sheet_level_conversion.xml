<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#E0E0E0" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bảng Quy Đổi Cấp Độ Chứng Chỉ"
        android:textColor="#1A1C1E"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:text="So sánh trình độ của bạn với các chứng chỉ quốc tế."
        android:textColor="#74777F"
        android:textSize="14sp" />

    <!-- Table Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#E0E0E0"
        app:strokeWidth="1dp">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="0,1,2,3">

            <!-- Table Header -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0066FF"
                android:paddingVertical="12dp">
                <TextView android:text="App" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_weight="1"/>
                <TextView android:text="CEFR" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_weight="1"/>
                <TextView android:text="IELTS" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_weight="1"/>
                <TextView android:text="TOEIC" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:layout_weight="1"/>
            </TableRow>

            <!-- Advanced Row -->
            <TableRow
                android:id="@+id/rowAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:paddingVertical="14dp">
                <TextView android:text="Cao cấp" android:textColor="#1A1C1E" android:textSize="12sp" android:textStyle="bold" android:gravity="center"/>
                <TextView android:text="B2" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
                <TextView android:text="5.5 - 6.5" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
                <TextView android:text="785 - 940" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
            </TableRow>

            <!-- Intermediate Row -->
            <TableRow
                android:id="@+id/rowIntermediate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F4F7FA"
                android:paddingVertical="14dp">
                <TextView android:text="Trung bình" android:textColor="#1A1C1E" android:textSize="12sp" android:textStyle="bold" android:gravity="center"/>
                <TextView android:text="B1" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
                <TextView android:text="4.0 - 5.0" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
                <TextView android:text="450 - 780" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
            </TableRow>

            <!-- Beginner Row -->
            <TableRow
                android:id="@+id/rowBeginner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:paddingVertical="14dp">
                <TextView android:text="Mới bắt đầu" android:textColor="#1A1C1E" android:textSize="12sp" android:textStyle="bold" android:gravity="center"/>
                <TextView android:text="A2" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
                <TextView android:text="3.0 - 3.5" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
                <TextView android:text="225 - 445" android:textColor="#74777F" android:textSize="12sp" android:gravity="center"/>
            </TableRow>

        </TableLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseSheet"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Đã hiểu"
        android:textAllCaps="false"
        app:cornerRadius="28dp"
        app:backgroundTint="#0066FF" />

</LinearLayout>