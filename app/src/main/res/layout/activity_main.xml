<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#4A6CF7"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/logo_bg"
            android:padding="6dp"
            android:src="@drawable/logo"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EnglishLearning"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"/>

    </LinearLayout>


    <!-- SEARCH -->
    <EditText
        android:id="@+id/searchInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:hint="Tìm từ vựng..."
        android:padding="12dp"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="10dp"
        android:background="@drawable/search_bg"
        android:textColor="#333"
        android:textColorHint="#9AA0A6"/>


    <!-- FEATURE -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:padding="14dp">

        <Button
            android:id="@+id/btnFlashcard"
            android:text="Flashcard"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A6CF7"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"/>

        <Button
            android:id="@+id/btnQuiz"
            android:text="Trắc nghiệm"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6C63FF"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"/>

        <Button
            android:id="@+id/btnFill"
            android:text="Điền từ"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF7A59"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"/>

        <Button
            android:id="@+id/btnListening"
            android:text="Luyện nghe"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2BB673"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"/>
    </GridLayout>


    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bài học hôm nay"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333"
        android:layout_marginStart="16dp"
        android:layout_marginTop="6dp"/>


    <!-- LESSON LIST -->
    <ListView
        android:id="@+id/listLesson"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:layout_weight="1"
        android:dividerHeight="8dp"
        android:divider="@android:color/transparent"/>


    <!-- BOTTOM NAVIGATION -->
    <include
        android:id="@+id/bottomBar"
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"/>


</LinearLayout>